# ─── LLM ────────────────────────────────────────────────────────────────────────
# Get your free key at: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Model options (free tier):
#   llama3-8b-8192    → fast, lightweight
#   llama3-70b-8192   → powerful, slower
#   mixtral-8x7b-32768→ large context window
GROQ_MODEL=llama3-70b-8192
GROQ_MAX_TOKENS=2048
GROQ_TEMPERATURE=0.2

# ─── Embeddings ─────────────────────────────────────────────────────────────────
# Free, runs locally — no API key needed
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DEVICE=cpu              # or "cuda" if you have a GPU

# ─── Vector Store ───────────────────────────────────────────────────────────────
CHROMA_PERSIST_DIR=./data/chroma_db
CHROMA_COLLECTION_NAME=rag_documents

# ─── Chunking ───────────────────────────────────────────────────────────────────
CHUNK_SIZE=512
CHUNK_OVERLAP=64

# ─── Retrieval ──────────────────────────────────────────────────────────────────
RETRIEVER_TOP_K=5                 # Number of chunks to retrieve per query

# ─── Critic ─────────────────────────────────────────────────────────────────────
CRITIC_SCORE_THRESHOLD=0.6        # Regenerate if score below this
CRITIC_MAX_RETRIES=2              # Max self-improvement iterations

# ─── Memory ─────────────────────────────────────────────────────────────────────
MEMORY_DIR=./data/memory
MAX_HISTORY_TURNS=10              # Turns to keep in active context

# ─── API ────────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true                   # Set false in production
ALLOWED_ORIGINS=*                 # Restrict in production: http://localhost:3000

# ─── Logging ────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO                    # DEBUG | INFO | WARNING | ERROR
